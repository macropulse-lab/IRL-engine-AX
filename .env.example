# IRL Engine — Environment Configuration
# Copy to .env and fill in values

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgres://irl_user:irl_pass@localhost:5432/irl

# ── Database (advanced) ───────────────────────────────────────────────────────
# Optional read-replica for analytics GET routes (list_traces, audit-log, etc.)
DB_READONLY_URL=
# Primary pool max connections. Default: 10. Use 25–50 for 100+ concurrent agents.
DB_POOL_MAX_CONNECTIONS=10
# Trace history retention in months (pg_partman). Default: 36.
DB_RETENTION_MONTHS=36

# ── MTA Mode ─────────────────────────────────────────────────────────────────
# "MacroPulse" (default) — connect to a live MTA operator, requires URL + pubkey below
# "mock"                 — built-in mock MTA, no external endpoint needed (dev/CI only)
MTA_MODE=MacroPulse

# ── MTA Operator (required when MTA_MODE=MacroPulse) ─────────────────────────
# MacroPulse (turnkey):  set MTA_URL to your MacroPulse instance
# Custom MTA:            set MTA_URL to your operator's endpoint and provide its Ed25519 pubkey
MTA_URL=https://your-mta-operator.com
MTA_PUBKEY_HEX=<64-char hex Ed25519 public key from your MTA operator>

# ── Auth ──────────────────────────────────────────────────────────────────────
# Comma-separated bearer tokens (one per client/fund/strategy)
# Generate with: openssl rand -hex 32
IRL_API_TOKENS=token-fund-a,token-fund-b

# ── Observability ─────────────────────────────────────────────────────────────
# Expose GET /metrics (Prometheus format). Default: true.
# Restrict to internal network at load-balancer/ingress level in production.
METRICS_ENABLED=true

# ── Rate Limiting & Body ──────────────────────────────────────────────────────
# Max requests per token per second. 0 = disabled. Default: 100.
RATE_LIMIT_PER_SECOND=100
# Max request body size in bytes. Default: 1048576 (1 MB).
MAX_BODY_BYTES=1048576

# ── Layer 2 Heartbeat ─────────────────────────────────────────────────────────
LAYER2_ENABLED=false
MAX_HEARTBEAT_DRIFT_MS=200

# ── KMS / Envelope Encryption ─────────────────────────────────────────────────
# Encrypt trace_json at rest using envelope encryption.
# Options: none (plaintext, default), local (dev/CI), aws, vault
KMS_PROVIDER=none
# AWS KMS: full key ARN (e.g. arn:aws:kms:us-east-1:123456789:key/mrk-...)
# Vault Transit: key name (e.g. irl-traces)
KMS_KEY_ID=
# Required when KMS_PROVIDER=aws
AWS_REGION=us-east-1
# Required when KMS_PROVIDER=vault
VAULT_ADDR=https://vault.example.com
VAULT_TOKEN=

# ── Post-Trade Verifier ───────────────────────────────────────────────────────
BIND_SIZE_TOLERANCE=0.0001
TRACE_EXPIRY_MS=3600000

# ── Time & Server ─────────────────────────────────────────────────────────────
# TIME_SOURCE: "System" (dev) or "NtpSynced" (prod — requires PTP/GPS clock)
TIME_SOURCE=System
PORT=4000
RUST_LOG=irl_engine=info,tower_http=debug
